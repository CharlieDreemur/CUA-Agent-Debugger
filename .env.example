# Copy this file to .env and fill only the providers you use.
# API keys are read from environment variables, never from debugger JSON config.

OPENAI_API_KEY=...
ANTHROPIC_API_KEY=...
TOGETHER_API_KEY=...

# OpenAI-compatible custom providers need both key and base URL.
GEMINI_API_KEY=...
GEMINI_BASE_URL=...
QWEN_API_KEY=...
QWEN_BASE_URL=...
SONNET_API_KEY=...
SONNET_BASE_URL=...
